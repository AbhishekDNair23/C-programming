SELECT DISTINCT * FROM Customers  INNER JOIN Orderss  ON Customers.Custid=Orderss.Custid;

SELECT DISTINcT * FROM Customers INNER JOIN Orderss ON Customers.Custid=Orderss.custid INNER JOIN Delivery on Delivery.orderid=Orderss.orderid;

SELECT c.Custname,o.Orderdate FROM Customers c INNER JOIN Orderss o ON c.Custid=o.Custid WHERE c.Custname LIKE 'J%';

SELECT i.Itemname,i.Price FROM Customers c INNER JOIN Orderss o ON c.Custid=o.Custid INNER JOIN Items i ON o.Itemid=i.Itemid WHERE c.Custname='Mickey';

SELECT DISTINCT c.* FROM Customers c INNER JOIN Orderss o ON c.Custid=o.Custid WHERE o.Orderdate>TO_DATE('31-JAN-2013','DD-MON-YYYY') AND NOT EXISTS (SELECT 1 FROM Delivery d WHERE d.Orderid=o.Orderid);

SELECT DISTINCT i.Itemid,i.Itemname FROM Items i INNER JOIN Orderss o ON i.Itemid=o.Itemid UNION SELECT DISTINCT i.Itemid,i.Itemname FROM Items i INNER JOIN Orderss o ON i.Itemid=o.Itemid LEFT JOIN Delivery d ON o.Orderid=d.Orderid WHERE d.Deliveryid IS NULL;

SELECT DISTINCT c.Custname FROM Customers c INNER JOIN Orderss o ON c.Custid=o.Custid INNER JOIN Delivery d ON o.Orderid=d.Orderid;

SELECT DISTINCT c.Custname FROM Customers c WHERE c.Custid IN (SELECT o.Custid FROM Orderss o) MINUS SELECT DISTINCT c.Custname FROM Customers c WHERE c.Custid IN (SELECT o.Custid FROM Orderss o JOIN Delivery d ON o.Orderid=d.Orderid);

SELECT * FROM (SELECT c.Custname,COUNT(o.Orderid) AS TotalOrders FROM Customers c JOIN Orderss o ON c.Custid=o.Custid GROUP BY c.Custname ORDER BY COUNT(o.Orderid) DESC) WHERE ROWNUM=1;

SELECT DISTINCT c.* FROM Customers c JOIN Orderss o ON c.Custid=o.Custid JOIN Items i ON o.Itemid=i.Itemid WHERE (o.Quantity*i.Price)>5000;

SELECT * FROM Customers c WHERE c.Custid NOT IN (SELECT o.Custid FROM Orderss o JOIN Items i ON o.Itemid=i.Itemid WHERE i.Itemname='Samsung GalaxyS4');

SELECT c.Custid,c.Custname,o.Orderid FROM Customers c LEFT JOIN Orderss o ON c.Custid=o.Custid;

SELECT c.Custid,c.Custname,o.Orderid FROM Customers c RIGHT JOIN Orderss o ON c.Custid=o.Custid;

SELECT State,COUNT(*) AS Total_Customers FROM Customers GROUP BY State;

SELECT Category,Itemname,Price FROM Items WHERE Price>(SELECT AVG(Price) FROM Items);
